# ============================================================================
# AUTOML PIPELINE CONFIGURATION
# ============================================================================

# ============================================================================
# DATA PATHS
# ============================================================================
DATA_PATH=data/reference.csv
REFERENCE_DATA_PATH=data/reference.csv
CURRENT_DATA_PATH=data/current.csv
TARGET_COLUMN=Survived

# ============================================================================
# DRIFT MONITORING
# ============================================================================
# Порог PSI (Population Stability Index) для обнаружения data drift
# PSI < 0.1: без изменений
# PSI 0.1-0.25: небольшие изменения
# PSI > 0.25: значительные изменения (DRIFT DETECTED)
DRIFT_THRESHOLD=0.2

# ============================================================================
# MLFLOW CONFIGURATION
# ============================================================================
MLFLOW_TRACKING_URI=./mlruns
MODEL_NAME=automl-best-model

# ============================================================================
# FLASK A/B TEST CONFIGURATION
# ============================================================================
# Доля трафика для Production модели (0.0-1.0)
# 0.5 = 50/50 split между Production и Staging
# 0.7 = 70% Production, 30% Staging
AB_TRAFFIC_SPLIT=0.5

# Стратегия A/B разделения: 'random' или 'user_id'
# random: случайное распределение на основе random()
# user_id: детерминированное на основе user_id % 2
AB_STRATEGY=random

# Flask конфигурация
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
FLASK_DEBUG=False

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_DIR=logs
LOG_LEVEL=INFO
